# ---- Data & output folders: empty in public repo, local-only contents ----
data/*
!data/.gitkeep
output/*
!output/.gitkeep

# ---- Raw data must stay local (analysis/ tracked, but not raw dumps) ----
BMC.txt
PoDM.txt
*.docx
*.doc
# analysis/ 下的 docx 是我们的生成报告 (非 source spec)，允许入库
!analysis/*.docx
!analysis/*.doc

# ---- Editor / IDE ----
.vscode/
.idea/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
